{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "brakode.dev"
        }
      ],
      "destination": "https://www.brakode.dev/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "magnus.brakode.dev"
        }
      ],
      "destination": "/magnus.html"
    }
  ]
}
